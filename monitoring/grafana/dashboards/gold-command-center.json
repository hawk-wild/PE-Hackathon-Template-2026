{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"url-shortener-apps\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Latency (p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"url-shortener-apps\"}[1m]))",
          "legendFormat": "fleet rps",
          "refId": "A"
        }
      ],
      "title": "Traffic (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"url-shortener-apps\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"url-shortener-apps\"}[5m])), 1)",
          "legendFormat": "fleet 5xx %",
          "refId": "A"
        }
      ],
      "title": "Errors (5xx Rate %)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "avg(process_cpu_usage_percent{job=\"url-shortener-apps\"})",
          "legendFormat": "avg cpu",
          "refId": "A"
        }
      ],
      "title": "Saturation (CPU %)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["gold", "command-center", "hackathon"],
  "time": {"from": "now-30m", "to": "now"},
  "title": "Tier 3 Gold - Command Center",
  "uid": "tier3-command-center",
  "version": 1
}
